#!/usr/bin/env bash
# Generated by Ansible — do not edit manually
set -euo pipefail

export BASE_URL="http://{{ endpoint_private_ip }}:5000"

{% for acct in hot_accounts %}
export HOT_ACCOUNT_{{ loop.index }}="{{ acct }}"
{% endfor %}

SCRIPT="${1:-main-exhaustion.js}"
shift || true

echo "=== BenchTest k6 Runner ==="
echo "BASE_URL:   $BASE_URL"
echo "Script:     $SCRIPT"
echo ""

exec k6 run \
  -e BASE_URL="$BASE_URL" \
{% for acct in hot_accounts %}
  -e HOT_ACCOUNT_{{ loop.index }}="{{ acct }}" \
{% endfor %}
  "$@" \
  "/opt/k6/$SCRIPT"
